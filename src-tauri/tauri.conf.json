{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PF2 离线百科",
  "version": "0.3.24",
  "identifier": "com.takaqiao.pf2wiki",
  "build": {
    "frontendDist": "../_tauri_placeholder"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "PF2 离线百科",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "center": true,
        "decorations": true,
        "resizable": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "publisher": "takaqiao",
    "category": "Education",
    "shortDescription": "PF2 中文百科离线镜像",
    "longDescription": "Pathfinder 2e 中文资料离线镜像，包含 36,000+ 条目。",
    "resources": [
      "../_wiki_full_v2/**/*"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "nsis": {
        "compression": "zlib"
      }
    }
  }
}
